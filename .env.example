# NanoClaw — Community Intelligence Bot
# Copy to .env and fill in values

# ── Required ──────────────────────────────────────────────────

# Anthropic API key (for Claude inside containers)
ANTHROPIC_API_KEY=

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# ── Memory (Mem0 cloud) ──────────────────────────────────────

# Mem0 API key (from mem0.ai dashboard)
MEM0_API_KEY=

# ── Constitution sync ────────────────────────────────────────

# Platform API URL
EMERGENTVIBE_API_URL=https://emergentvibe.com

# Bot secret for member registration API
BOT_API_SECRET=

# Groups to sync (JSON array)
GROUPS_CONFIG=[]

# ── Self-hosted Memory (recommended for community deployment) ─

# Self-hosted Mem0 SSE URL (overrides MEM0_API_KEY if set)
# Run: docker compose -f docker-compose.mem0.yml up -d
# Then set: MEM0_SSE_URL=http://localhost:8765/sse
# MEM0_SSE_URL=

# OpenAI API key (required by OpenMemory for embeddings)
# OPENAI_API_KEY=

# ── Optional ──────────────────────────────────────────────────

# Bot name (default: Andy)
# ASSISTANT_NAME=Andy

# Max concurrent containers (default: 10)
# MAX_CONCURRENT_CONTAINERS=10

# Constitution sync interval in ms (default: 300000 = 5 minutes)
# SYNC_INTERVAL_MS=300000
