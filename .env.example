# NanoClaw — Community Intelligence Bot
# Copy to .env and fill in values

# ── Required ──────────────────────────────────────────────────

# Anthropic API key (for Claude inside containers)
ANTHROPIC_API_KEY=

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# ── Memory (Mem0 cloud) ──────────────────────────────────────

# Mem0 API key (from mem0.ai dashboard)
MEM0_API_KEY=

# ── Constitution sync ────────────────────────────────────────

# Platform API URL
EMERGENTVIBE_API_URL=https://emergentvibe.com

# Bot secret for member registration API
BOT_API_SECRET=

# Groups to sync (JSON array)
GROUPS_CONFIG=[]

# ── Optional ──────────────────────────────────────────────────

# Bot name (default: Andy)
# ASSISTANT_NAME=Andy

# Max concurrent containers (default: 10)
# MAX_CONCURRENT_CONTAINERS=10

# Self-hosted Mem0 (overrides MEM0_API_KEY if set)
# MEM0_SSE_URL=http://localhost:8765/sse
